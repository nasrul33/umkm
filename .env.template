# Salin ke .env per instalasi klien — JANGAN commit .env asli ke git.
DOMAIN=namaklien.example.com
DB_NAME=siaumkm
DB_USER=siaumkm
DB_PASSWORD=changeme_generate_random
# Secret JWT per instalasi — minimal 32 karakter acak, jangan pakai contoh ini.
JWT_SECRET=changeme_generate_random_min_32_chars
JWT_EXPIRY_MINUTES=480
# Kunci enkripsi kolom sensitif (NFR-05) — WAJIB hasil `openssl rand -base64 32`.
# PERINGATAN: simpan salinan aman; kehilangan kunci = NPWP/NIK tak bisa dibaca lagi.
FIELD_ENCRYPTION_KEY=changeme_openssl_rand_base64_32
PJAP_PROVIDER=pajakku
PJAP_BASE_URL=https://api.pjap-mitra.example.com
PJAP_API_KEY=changeme_simpan_terenkripsi
